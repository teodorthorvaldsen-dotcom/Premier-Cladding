# Resend API key for email delivery. Get one at https://resend.com/api-keys
# Required for cart checkout emails to BOTH the customer and the business.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Extra business inbox for cart/quote copy (optional). premiercladdingsolutions@gmail.com is always included in code.
BUSINESS_EMAIL=premiercladdingsolutions@gmail.com

# "From" address for outgoing emails. Use onboarding@resend.dev for testing,
# or a verified domain (e.g. noreply@yourdomain.com) for production.
EMAIL_FROM=onboarding@resend.dev

# Password for /admin/quotes page (quote requests list)
ADMIN_PASSWORD=your-admin-password
