# Resend API key for email delivery. Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Sender address — must be verified in the Resend dashboard (e.g. orders@yourdomain.com).
EMAIL_FROM=orders@yourdomain.com

# Inbox that receives new order notifications from checkout (team email).
ORDER_NOTIFICATION_EMAIL=you@yourdomain.com

# Optional: extra business copy for single-item quote API (see src/app/api/quote/route.ts)
BUSINESS_EMAIL=quotes@yourcompany.com

# Password for /admin/quotes page (quote requests list)
ADMIN_PASSWORD=your-admin-password

# JWT signing secret for /login and /portal (copy to .env.local; never commit .env.local)
JWT_SECRET=super-secret-change-this-in-production
